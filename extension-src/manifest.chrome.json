{
  "manifest_version": 3,
  "name": "DocuFlux Capture",
  "version": "1.0.0",
  "description": "Capture authenticated web content and send to DocuFlux for conversion",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://cdn2.percipio.com/*", "*://*.percipio.com/*"],
  "optional_host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DocuFlux Capture"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "content_scripts": [
    {
      "matches": ["https://cdn2.percipio.com/*", "*://*.percipio.com/*"],
      "js": ["percipio-frame.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
