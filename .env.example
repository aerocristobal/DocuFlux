# DocuFlux Environment Configuration
# Copy this file to .env and update values for your deployment

# ============================================
# Security Configuration
# ============================================

# Flask secret key for session encryption
# CRITICAL: Change this in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Enable Flask debug mode (default: false, never enable in production)
# FLASK_DEBUG=false

# Session lifetime in days (default: 30)
# PERMANENT_SESSION_LIFETIME_DAYS=30

# ============================================
# HTTPS / Cloudflare Tunnel Configuration
# ============================================

# Cloudflare Tunnel token (Epic 22.1)
# Create tunnel at: https://one.dash.cloudflare.com/
# Or use: cd cloudflare && ./setup.sh
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# Enable secure cookies when behind HTTPS proxy (Epic 22.4)
# Set to 'true' when using Cloudflare Tunnel or other HTTPS termination
SESSION_COOKIE_SECURE=false

# Enable ProxyFix middleware (Epic 22.4)
# Set to 'true' when behind Cloudflare Tunnel or reverse proxy
BEHIND_PROXY=false

# ============================================
# Redis Configuration
# ============================================

# Redis authentication password (required - set a strong random value)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
REDIS_PASSWORD=change-me-redis-password

# Celery broker (task queue) - DB 0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Celery result backend - DB 0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# Job metadata and WebSocket storage - DB 1
REDIS_METADATA_URL=redis://:${REDIS_PASSWORD}@redis:6379/1

# ============================================
# Storage Configuration
# ============================================

# File upload storage directory
UPLOAD_FOLDER=data/uploads

# Converted file output directory
OUTPUT_FOLDER=data/outputs

# ============================================
# GPU Configuration (Epic 21)
# ============================================

# Build-time GPU flag (for Docker builds)
# AUTO: Auto-detect GPU during build
# true: Force GPU build (~15GB image)
# false: Force CPU build (~3GB image)
BUILD_GPU=AUTO

# Runtime feature flag (auto-detected by worker)
# MARKER_ENABLED=true

# VRAM allocation for Marker AI (auto-detected by worker)
# INFERENCE_RAM=16

# Encryption key for data at rest
# Auto-generated in dev if not set. CRITICAL: Set a persistent key in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# MASTER_ENCRYPTION_KEY=your-encryption-key-here

# Celery message signing key
# Auto-generated in dev if not set. Set in production for message integrity.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# CELERY_SIGNING_KEY=your-signing-key-here

# ============================================
# Storage Limits
# ============================================

# Maximum upload size (bytes, default 200MB)
MAX_CONTENT_LENGTH=209715200

# Minimum free disk space before rejecting uploads (bytes, default 500MB)
MIN_FREE_SPACE=524288000

# ============================================
# Browser Extension / Capture Settings
# ============================================

# Capture session time-to-live in seconds (default 24h)
CAPTURE_SESSION_TTL=86400

# Maximum pages per capture session
MAX_CAPTURE_PAGES=500

# Pages per batch during capture processing
CAPTURE_BATCH_SIZE=50

# Allowed capture origins (JSON array, default: chrome/firefox extensions)
# CAPTURE_ALLOWED_ORIGINS=["chrome-extension://*","moz-extension://*"]

# ============================================
# AI / Model Configuration
# ============================================

# Path to local SLM model (optional, leave empty to disable)
# SLM_MODEL_PATH=

# Maximum context tokens for SLM inference
MAX_SLM_CONTEXT=2000

# Maximum pages for Marker AI processing
MAX_MARKER_PAGES=600

# ============================================
# Service URLs
# ============================================

# MCP server endpoint
MCP_SERVER_URL=http://mcp-server:8080/execute

# ============================================
# WebSocket / CORS Configuration
# ============================================

# Socket.IO async mode (eventlet|gevent|threading|fork)
# SOCKETIO_ASYNC_MODE=eventlet

# Socket.IO message queue URL (defaults to REDIS_METADATA_URL)
# SOCKETIO_MESSAGE_QUEUE=

# Restrict Socket.IO WebSocket connections to specific origins
# Default: '*' (allow all). Set to comma-separated origins for production.
# Example: SOCKETIO_CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
# SOCKETIO_CORS_ALLOWED_ORIGINS=

# ============================================
# Monitoring
# ============================================

# Prometheus metrics exporter port
METRICS_PORT=9090

# ============================================
# Rate Limiting
# ============================================

# Default rate limits (JSON array)
# FLASK_LIMITER_DEFAULT_LIMITS=["1000 per day","200 per hour"]

# Rate limiter storage backend (defaults to REDIS_METADATA_URL)
# FLASK_LIMITER_STORAGE_URI=

# ============================================
# Redis TLS (Optional)
# ============================================

# Uncomment for TLS-encrypted Redis connections
# CELERY_BROKER_URL=rediss://redis:6379/0
# REDIS_METADATA_URL=rediss://redis:6379/1
# REDIS_TLS_CA_CERTS=/path/to/ca.pem
# REDIS_TLS_CERTFILE=/path/to/cert.pem
# REDIS_TLS_KEYFILE=/path/to/key.pem
